\begin{algo}{fibonacci}{n}
    \IF { n <= 1 }
        \RETURN { n }
    \ELSE
        \RETURN { \CALL{fibonacci}{n - 1} + \CALL{fibonacci}{n - 2} }
    \FI
\end{algo}

\begin{algo}{fact_iter}{n}
    \SET { res } { 1 }
    \SET { i } { 1 }
    \DOWHILE { i <= n }
        \SET { res } { res * i }
        \SET { i } { i + 1 }
    \OD
    \RETURN { res }
\end{algo}

\begin{algo}{sum_evens}{start, end}
    \SET { sum } { 0 }
    \DOFORI { i } { start } { end }
        \SET { rem } { i - ((i / 2) * 2) }
        \IF { rem = 0 }
            \SET { sum } { sum + i }
        \FI
    \OD
    \RETURN { sum }
\end{algo}

\begin{algo}{math_stress}{a, b, c}
    \SET { x } { a * b }
    \SET { y } { c / 2 }
    \SET { z } { x + y - a }
    \RETURN { z }
\end{algo}

